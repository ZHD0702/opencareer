# OpenCareer Demo Environment Variables
# Copy this file to .env and fill in your values

# ======================
# API Keys and Services
# ======================

# DeepSeek API (for Brain Agent)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-6669c421876e487592af556c3f5ed6db
DEEPSEEK_API_BASE=https://api.deepseek.com

# Optional: OpenAI API (fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ======================
# Database and Storage
# ======================

# Redis (for dramatiq task queue)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# ChromaDB Vector Database
CHROMA_DB_PATH=./data/chromadb
CHROMA_COLLECTION_NAME=opencareer_memory
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# SQLite (for structured memory)
SQLITE_DB_PATH=./data/opencareer.db

# ======================
# Application Settings
# ======================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Settings
AGENT_RESPONSE_TIMEOUT=30  # seconds
MAX_CONVERSATION_HISTORY=50

# Brain Agent Settings
BRAIN_AGENT_MODEL=deepseek-chat
BRAIN_AGENT_TEMPERATURE=0.7
BRAIN_AGENT_MAX_TOKENS=1000

# Work Agent Settings
WORK_AGENT_DEFAULT_SKILLS=learning_plan,mock_interview

# Emotion Agent Settings
EMOTION_AGENT_SENTIMENT_ANALYSIS=true

# Log Agent Settings
LOG_AGENT_EXTRACTION_ENABLED=true
LOG_AGENT_MIN_CONFIDENCE=0.7

# ======================
# MCP Server Settings
# ======================

MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001
MCP_SERVER_WORKERS=4
MCP_SKILLS_DIR=./opencareer/skills

# ======================
# Network / Proxy
# ======================

NO_PROXY=localhost,127.0.0.1

# ======================
# Security
# ======================

# ======================
# Web API Server
# ======================

WEB_API_HOST=0.0.0.0
WEB_API_PORT=8080

# ======================
# Security
# ======================

# CORS settings (for web interface)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ======================
# Development Settings
# ======================

# Debug mode (set to false in production)
DEBUG=true

# Test mode (for automated testing)
TEST_MODE=false

# ======================
# Notes
# ======================

# 1. For local development, you can use a local Redis instance:
#    docker run -p 6379:6379 redis:alpine

# 2. ChromaDB will create the database directory automatically

# 3. SQLite database will be created automatically if it doesn't exist

# 4. To get a DeepSeek API key:
#    - Visit https://platform.deepseek.com/
#    - Sign up for an account
#    - Navigate to API keys section
#    - Create a new API key

# 5. For production deployment, ensure all sensitive values are properly secured
#    and consider using a secrets management system.